---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Lance Owide">
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-text">
        <div class="hero-eyebrow">Hi, I'm Lance</div>
        <h1 class="hero-title">Building the future<br />of B2B commerce.</h1>
        <p class="hero-desc">
          General Manager B2B at BigCommerce. I think about commerce, AI, and
          how technology is reshaping the way businesses buy and sell.
        </p>
        <div class="hero-actions">
          <a href="/about" class="btn btn-primary">About me</a>
          <a href="/contact" class="btn btn-secondary">Get in touch</a>
        </div>
        <div class="hero-social">
          <a href="https://www.linkedin.com/in/lance-owide/" target="_blank" rel="noopener" class="social-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
        </div>
      </div>
      <div class="hero-image">
        <img src="/headshot.jpg" alt="Lance Owide" class="headshot" />
      </div>
    </div>
  </section>

  <!-- Recent Media -->
  <section class="home-section">
    <div class="home-section-inner">
      <div class="section-header">
        <h2 class="section-title">In the Media</h2>
        <a href="/media" class="section-link">View all →</a>
      </div>
      <div class="card-grid">
        <a href="https://www.bigcommerce.com/blog/distributed-ecommerce-hub/" target="_blank" rel="noopener" class="card media-card">
          <div class="media-outlet">BigCommerce Blog · Press</div>
          <div class="media-title">Introducing Distributed Ecommerce Hub</div>
          <div class="media-meta">Press · Feb 2026</div>
        </a>
        <a href="https://podcasts.apple.com/us/podcast/creating-the-silent-salesman-mtm-recognitions-journey/id1804419880?i=1000736605599&uo=4" target="_blank" rel="noopener" class="card media-card">
          <div class="media-outlet">B2B Bites Podcast — BigCommerce</div>
          <div class="media-title">Creating the Silent Salesman: MTM Recognition's Journey</div>
          <div class="media-meta">Podcast Host · Nov 2025</div>
        </a>
        <a href="https://www.digitalcommerce360.com/2025/09/17/how-agentic-ai-is-redefining-b2b-digital-commerce/" target="_blank" rel="noopener" class="card media-card">
          <div class="media-outlet">Digital Commerce 360</div>
          <div class="media-title">Q&A: How Agentic AI Is Redefining B2B Digital Commerce</div>
          <div class="media-meta">Interview · Sep 2025</div>
        </a>
      </div>
    </div>
  </section>

  <!-- Recent Projects -->
  <section class="home-section">
    <div class="home-section-inner">
      <div class="section-header">
        <h2 class="section-title">Projects</h2>
        <a href="/projects" class="section-link">View all →</a>
      </div>
      <div class="card-grid">
        <div class="card">
          <div class="project-title">AI Commerce Experiments</div>
          <div class="project-desc">Exploring how large language models can be applied to B2B purchasing workflows and catalog management.</div>
          <div class="tags">
            <span class="tag">AI</span>
            <span class="tag">Commerce</span>
            <span class="tag">B2B</span>
          </div>
        </div>
        <div class="card">
          <div class="project-title">More coming soon</div>
          <div class="project-desc">Working on a few interesting projects. Check back soon.</div>
          <div class="tags">
            <span class="tag">AI</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .hero {
    border-bottom: 1px solid var(--border);
  }

  .hero-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 5rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 4rem;
    justify-content: space-between;
  }

  .hero-text {
    flex: 1;
    min-width: 0;
  }

  .hero-eyebrow {
    font-size: 0.9rem;
    color: var(--accent);
    font-weight: 500;
    margin-bottom: 1rem;
    letter-spacing: 0.02em;
  }

  .hero-title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1.25rem;
  }

  .hero-desc {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 480px;
    line-height: 1.7;
    margin-bottom: 2rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1.75rem;
  }

  .hero-social {
    display: flex;
    gap: 1rem;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    transition: color 0.15s;
  }

  .social-link:hover {
    color: var(--text);
  }

  .hero-image {
    flex-shrink: 0;
  }

  .headshot {
    width: 220px;
    height: 220px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--border);
    background: var(--surface);
  }

  /* Home sections */
  .home-section {
    border-bottom: 1px solid var(--border);
  }

  .home-section-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 3.5rem 1.5rem;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .section-title {
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .section-link {
    font-size: 0.85rem;
    color: var(--accent);
    transition: color 0.15s;
  }

  .section-link:hover {
    color: var(--accent-hover);
  }

  /* Media cards */
  .media-card {
    display: block;
    text-decoration: none;
  }

  .media-outlet {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .media-title {
    font-size: 0.95rem;
    font-weight: 500;
    line-height: 1.4;
    margin-bottom: 0.5rem;
  }

  .media-meta {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  /* Project cards */
  .project-title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .project-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  @media (max-width: 680px) {
    .hero-inner {
      flex-direction: column-reverse;
      padding: 3rem 1rem;
      gap: 2rem;
      text-align: center;
    }

    .hero-desc {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-social {
      justify-content: center;
    }

    .headshot {
      width: 160px;
      height: 160px;
    }
  }
</style>
