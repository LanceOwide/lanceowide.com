const filters: { key: FilterKey; label: string }[] = [
  { key: 'all', label: 'All' },
  { key: 'host', label: 'Podcast Host' },
  { key: 'guest', label: 'Podcast Guest' },
  { key: 'writing', label: 'Writing' },
  { key: 'conference', label: 'Conference' },
  { key: 'press', label: 'Press' },
  { key: 'video', label: 'Video & Webinar' },
];

const counts: Record<FilterKey, number> = {
  all: appearances.length,
  host: appearances.filter(a => a.filter === 'host').length,
  guest: appearances.filter(a => a.filter === 'guest').length,
  writing: appearances.filter(a => a.filter === 'writing').length,
  conference: appearances.filter(a => a.filter === 'conference').length,
  press: appearances.filter(a => a.filter === 'press').length,
  video: appearances.filter(a => a.filter === 'video').length,
};
---

<Layout
  title="Media — Lance Owide"
  description="Podcast appearances, interviews, keynotes, and articles featuring Lance Owide on B2B commerce, AI, and digital transformation."
>
  <div class="page">
    <div class="page-header">
      <div class="page-label">Media</div>
      <h1 class="page-title">Appearances & Press</h1>
      <p class="page-desc">Podcasts, keynotes, interviews, and writing on B2B commerce, AI, and digital transformation.</p>
    </div>

    <div class="filters" role="tablist">
      {filters.map(({ key, label }) => (
        <button
          class:list={['filter-btn', { active: key === 'all' }]}
          data-filter={key}
          role="tab"
          aria-selected={key === 'all'}
        >
          {label}
          <span class="filter-count">{counts[key]}</span>
        </button>
      ))}
    </div>

    <div class="media-list" id="media-list">
      {appearances.map((item) => (
        <a
          href={item.url}
          target="_blank"
          rel="noopener"
          class:list={['media-item', { 'has-image': !!item.image }]}
          data-filter={item.filter}
        >
          {item.image && (
            <div class="media-thumb">
              <img src={item.image} alt={item.title} loading="lazy" />
            </div>
          )}
          <div class="media-item-body">
            <div class="media-top">
              <span class={`badge badge-${item.filter}`}>{item.badge}</span>
              <span class="media-date">{item.date}</span>
            </div>
            <div class="media-outlet">{item.outlet}</div>
            <div class="media-title">{item.title}</div>
            <div class="media-desc">{item.description}</div>
          </div>
          <div class="media-arrow">→</div>
        </a>
      ))}
    </div>

    <div class="no-results" id="no-results" style="display:none">
      No results for this filter.
    </div>
  </div>
</Layout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items = document.querySelectorAll<HTMLElement>('.media-item');
  const noResults = document.getElementById('no-results')!;

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter!;

      buttons.forEach(b => {
        b.classList.toggle('active', b === btn);
        b.setAttribute('aria-selected', String(b === btn));
      });

      let visible = 0;
      items.forEach(item => {
        const show = filter === 'all' || item.dataset.filter === filter;
        item.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      noResults.style.display = visible === 0 ? 'block' : 'none';
    });
  });
</script>

<style>
  .filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 2rem;
  }

  .filter-btn {
