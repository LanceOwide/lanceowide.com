    color: var(--text-subtle);
  }

  .media-outlet {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-subtle);
    margin-bottom: 0.25rem;
  }

  .media-title {
    font-size: 0.95rem;
    font-weight: 600;
    line-height: 1.4;
    color: var(--text);
    margin-bottom: 0.35rem;
  }

  .media-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .media-thumb {
    flex-shrink: 0;
    width: 140px;
    height: 90px;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--surface-2);
  }

  .media-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .media-arrow {
    flex-shrink: 0;
    color: var(--text-subtle);
    font-size: 1rem;
    padding-top: 0.2rem;
    transition: color 0.15s, transform 0.15s;
  }

  .media-item:hover .media-arrow {
    color: var(--accent);
    transform: translateX(3px);
  }

  .no-results {
    padding: 3rem 0;
    text-align: center;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  @media (max-width: 600px) {
    .media-arrow { display: none; }
    .media-thumb { display: none; }
  }
</style>
