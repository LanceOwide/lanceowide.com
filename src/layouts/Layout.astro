---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Lance Owide — General Manager B2B at BigCommerce. Writing and speaking about B2B commerce, AI, and product strategy.',
  ogImage = '/og.png',
} = Astro.props;

const currentPath = Astro.url.pathname;

const nav = [
  { label: 'About', href: '/about' },
  { label: 'Media', href: '/media' },
  { label: 'Projects', href: '/projects' },
  { label: 'Contact', href: '/contact' },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`https://lanceowide.com${ogImage}`} />
    <meta property="og:url" content={`https://lanceowide.com${currentPath}`} />
    <meta property="og:type" content="website" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`https://lanceowide.com${ogImage}`} />

    <!-- JSON-LD Person schema -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Lance Owide",
        "jobTitle": "General Manager B2B",
        "worksFor": { "@type": "Organization", "name": "BigCommerce" },
        "url": "https://lanceowide.com",
        "sameAs": [
          "https://www.linkedin.com/in/lance-owide/"
        ]
      }
    </script>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>

  <body>
    <header>
      <nav class="nav-inner">
        <a href="/" class="nav-logo">Lance Owide</a>
        <ul class="nav-links">
          {nav.map(({ label, href }) => (
            <li>
              <a
                href={href}
                class:list={['nav-link', { active: currentPath === href || (href !== '/' && currentPath.startsWith(href)) }]}
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="footer-inner">
        <span class="footer-name">Lance Owide</span>
        <div class="footer-links">
          <a href="https://www.linkedin.com/in/lance-owide/" target="_blank" rel="noopener">LinkedIn</a>
        </div>
        <span class="footer-copy">© {new Date().getFullYear()}</span>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --bg: #090909;
    --surface: #111111;
    --surface-2: #161616;
    --border: #1e1e1e;
    --text: #f0f0f0;
    --text-muted: #666;
    --text-subtle: #444;
    --accent: #6366f1;
    --accent-hover: #818cf8;
    --radius: 12px;
    --max-width: 960px;
    --nav-height: 64px;
  }

  html {
    background: var(--bg);
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
    font-size: 16px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    max-width: 100%;
    display: block;
  }

  /* Nav */
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--nav-height);
    border-bottom: 1px solid var(--border);
    background: rgba(9, 9, 9, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-weight: 600;
    font-size: 1rem;
    letter-spacing: -0.01em;
    color: var(--text);
    transition: color 0.15s;
  }

  .nav-logo:hover {
    color: var(--accent-hover);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
  }

  .nav-link {
    padding: 0.4rem 0.75rem;
    border-radius: 8px;
    font-size: 0.9rem;
    color: var(--text-muted);
    transition: color 0.15s, background 0.15s;
  }

  .nav-link:hover {
    color: var(--text);
    background: var(--surface-2);
  }

  .nav-link.active {
    color: var(--text);
    background: var(--surface-2);
  }

  /* Footer */
  footer {
    border-top: 1px solid var(--border);
    padding: 2rem 1.5rem;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-name {
    font-weight: 500;
    font-size: 0.9rem;
  }

  .footer-links {
    display: flex;
    gap: 1.25rem;
  }

  .footer-links a {
    font-size: 0.85rem;
    color: var(--text-muted);
    transition: color 0.15s;
  }

  .footer-links a:hover {
    color: var(--text);
  }

  .footer-copy {
    font-size: 0.85rem;
    color: var(--text-subtle);
  }

  /* Shared page layout */
  .page {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }

  .page-header {
    margin-bottom: 3rem;
  }

  .page-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .page-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .page-desc {
    margin-top: 0.75rem;
    font-size: 1.05rem;
    color: var(--text-muted);
    max-width: 560px;
  }

  /* Cards */
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.5rem;
    transition: border-color 0.2s, background 0.2s;
  }

  .card:hover {
    border-color: #2e2e2e;
    background: var(--surface-2);
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  /* Tags */
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.75rem;
  }

  .tag {
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    color: var(--text-muted);
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.25rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s;
    text-decoration: none;
  }

  .btn-primary {
    background: var(--accent);
    color: #fff;
  }

  .btn-primary:hover {
    background: var(--accent-hover);
  }

  .btn-secondary {
    background: var(--surface);
    color: var(--text);
    border: 1px solid var(--border);
  }

  .btn-secondary:hover {
    background: var(--surface-2);
    border-color: #2e2e2e;
  }

  @media (max-width: 600px) {
    .page {
      padding: 2.5rem 1rem;
    }

    .nav-logo {
      font-size: 0.9rem;
    }

    .nav-link {
      padding: 0.4rem 0.5rem;
      font-size: 0.85rem;
    }
  }
</style>
